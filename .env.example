# Pickova environment variables
# Copy this file to .env.local and fill in real values.

# Database. Local dev uses SQLite (put this in .env so the Prisma CLI reads it):
#   DATABASE_URL="file:./dev.db"
# Production (Postgres/Neon) — set provider="postgresql" in prisma/schema.prisma:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="file:./dev.db"

# Paystack keys (test or live). If the SECRET key is left as a placeholder,
# checkout runs in MOCK mode (orders are created + auto-marked paid, no real
# charge) so the flow is testable without live keys.
NEXT_PUBLIC_PAYSTACK_KEY=<your-paystack-public-key>
PAYSTACK_SECRET_KEY=<your-paystack-secret-key>

# Jumia affiliate/publisher id — appended to affiliate product links
NEXT_PUBLIC_JUMIA_AFFILIATE_ID=your_jumia_affiliate_id

# WhatsApp order number in international format, no + or spaces (e.g. 234803XXXXXXX)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# Public site URL (used for metadata / canonical + Paystack callback)
NEXT_PUBLIC_SITE_URL=https://pickova.com.ng

# Bright Data (optional) — enables importing products from bot-protected
# retailers (Amazon, AliExpress, Jumia) via the Web Unlocker. Leave unset to
# use the free metadata importer only.
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=web_unlocker1

# Email (Resend) — optional. Sends order confirmations to buyers + new-order
# alerts to you. Dormant (no emails sent) until RESEND_API_KEY is set.
RESEND_API_KEY=
# Verified sender. Use onboarding@resend.dev for tests; switch to your domain
# (e.g. "Pickova <orders@pickova.com.ng>") once verified in Resend.
EMAIL_FROM=Pickova <onboarding@resend.dev>
# Where new-order alerts go (falls back to ADMIN_EMAIL if unset)
ADMIN_ORDER_EMAIL=

# Admin auth — session signing secret (generate a long random string for prod)
AUTH_SECRET=change-me-to-a-long-random-string
# Seed admin credentials (used by the DB seed to create the first admin user)
ADMIN_EMAIL=admin@pickova.com.ng
ADMIN_PASSWORD=change-me
